BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789
VENICE_API_KEY=your_venice_api_key
DATABASE_URL=postgresql+asyncpg://aibot_user:password@localhost/aibot_db
REDIS_URL=redis://localhost:6379
ADMIN_SECRET_KEY=your_admin_password
ADMIN_PORT=8080

# Webhook public host (required for payment provider webhooks)
WEBHOOK_HOST=https://your-domain.com

# YooKassa — payments for CIS/Russia (RUB)
# Register at https://yookassa.ru and get Shop ID + Secret Key
YOOKASSA_SHOP_ID=your_yookassa_shop_id
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxxxxxxxxx
YOOKASSA_RETURN_URL=https://t.me/your_bot

# Stripe — payments for Europe / USA (USD)
# Register at https://stripe.com, use test keys during development
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_SUCCESS_URL=https://t.me/your_bot?start=paid
STRIPE_CANCEL_URL=https://t.me/your_bot
